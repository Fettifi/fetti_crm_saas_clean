# Optimal Blue / Loansifter live-pricing connector — configuration template.
#
# These can live in .env.local OR (preferred) be set at runtime in app_settings
# via the same mechanism as META_*/TIKTOK_* (the adapter reads DB-first via cfg()).
# Every value comes from your AUTHENTICATED Optimal Blue "Digital Marketplace"
# portal (https://digitalmarketplace.optimalblue.com) or the credentials package
# OB onboarding sends you. NONE are public — do not guess; do not commit secrets.
#
# Prerequisite: confirm your account has programmatic OAuth client credentials
# entitled to "Broker Product & Pricing" (Loansifter). A plain Loansifter web
# subscription typically does NOT include this — it needs partner certification
# or routing through an already-certified partner.

# --- Required (minimum to attempt a connection) ---
OB_TOKEN_URL=            # OAuth2 token endpoint (Azure AD tenant /oauth2/token)
OB_CLIENT_ID=            # OAuth2 client id (from OB onboarding)
OB_CLIENT_SECRET=        # OAuth2 client secret — SECRET, never commit/log
OB_API_BASE=             # APIM gateway base URL (shown in the portal after login)
OB_PRICING_PATH=         # path of the Scenario Pricing / BESTX search call (from the Swagger)

# --- Auth options ---
OB_RESOURCE=             # resource/audience value (controls the JWT roles); scope string if v2
OB_TOKEN_PARAM_STYLE=resource   # "resource" (Azure AD v1) or "scope" (v2)
OB_SUBSCRIPTION_KEY=     # only if OB's APIM requires Ocp-Apim-Subscription-Key
OB_AUTH_HEADER=Authorization
OB_AUTH_SCHEME=Bearer
OB_PRICING_METHOD=POST

# --- Routing identity (OB "Configuration Reports > Entity Selection") ---
OB_BUSINESS_CHANNEL=     # Entity_ID
OB_ORIGINATOR_ID=        # user_index (per-loan-officer originator id)

# --- Field maps (copy the exact keys from the Swagger request/response examples) ---
# OB_REQUEST_MAP: our scenario key -> OB's dot-path in the request body, e.g.
#   {"loanAmount":"loanInformation.baseLoanAmount","fico":"borrower.creditScore","state":"property.state"}
OB_REQUEST_MAP=
# OB_REQUEST_STATIC: constant fields to merge into every request body (JSON)
OB_REQUEST_STATIC=
# OB_RESPONSE_MAP: { "productsPath": "...", "fields": { our: obKey, ... } }, e.g.
#   {"productsPath":"products","fields":{"noteRate":"rate","pricePercent":"price","lockDays":"lockPeriod"}}
OB_RESPONSE_MAP=
# OB_LOANTYPE_MAP: OB loan-type value -> our enum, e.g. {"CONF":"Conventional","NONQM":"NonQM"}
OB_LOANTYPE_MAP=
OB_PRICE_IS_COST=false   # set true if OB returns cost/points instead of price% of par
OB_TERM_IS_YEARS=false   # set true if OB returns term in years

# --- Behavior ---
OB_LENDER_ID=optimal-blue
OB_LENDER_NAME=Optimal Blue (Loansifter)
# OB_SYNC_SCENARIOS: standing scenarios to sweep on each pull (OB prices a scenario, not a flat sheet)
#   [{"loanAmount":400000,"propertyValue":500000,"fico":740,"occupancy":"PrimaryResidence","purpose":"Purchase","loanType":"Conventional","state":"CA"}]
OB_SYNC_SCENARIOS=
OB_KEEP_INELIGIBLE=false
OB_TIMEOUT_MS=12000
